.gradle
**/build/
!**/src/**/build/

# Forge / NeoForge dev-runtime data
run/
run-data/
runs/
runClient/
runServer/
runData/
mcmodsrepo/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# IntelliJ IDEA — ignore per-user state, but keep shared run configs / code style.
.idea/*
!.idea/runConfigurations/
!.idea/codeStyles/
*.iml
